const evidenceHighlights = [
  "CI crosses a real machine boundary; no localhost shortcuts.",
  "Configuration is env-driven through WEB_BASE_URL and API_BASE_URL.",
  "GitLab artifacts support debug-without-rerun diagnosis.",
  "Test data and state reset are designed for idempotent, parallel-friendly runs.",
  "Release gates are explicit and mapped to risk rather than vanity coverage.",

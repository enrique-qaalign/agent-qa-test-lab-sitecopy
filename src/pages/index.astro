---
const site = {
  title: "QA Test Lab",
  tagline:
    "Production-realistic QA automation practice—without enterprise overhead.",
};

const sprintHighlights = [
  {
    num: 0,
    status: "done",
    title: "Golden VM baseline",
    proof: "A clean baseline with deterministic access and a rollback snapshot.",
    deliverable: "Ubuntu Server + updates + SSH keys + snapshot.",
    runbooks: [
      {
        label: "Runbook 00 — Golden VM baseline (Ubuntu Server + SSH keys + snapshot)",
        href: "runbooks/runbook-00-golden-vm-baseline.html",
      },
    ],
    video: { label: "Sprint 0 demo", youtubeId: null },
  },
  {
    num: 1,
    status: "done",
    title: "Baseline topology (CI runner → SUT)",
    proof: "Tests cross a real network boundary. No localhost shortcuts.",
    deliverable: "Topology + runbook + working Compose SUT.",
    runbooks: [
      {
        label: "Runbook 01 — Runner → SUT connectivity and naming",
        href: "runbooks/runbook-01-runner-to-sut.html",
      },
    ],
    video: { label: "Sprint 1 demo", youtubeId: null },
  },
  {
    num: 2,
    status: "done",
    title: "Environment control (baseURL discipline)",
    proof: "Configuration lives in the environment, not the test code.",
    deliverable: "Hard fail → evidence → clean fix via env baseURL.",
    runbooks: [
      {
        label: "Runbook 02 — Compose deploy (dev) + health check",
        href: "runbooks/runbook-02-compose-deploy.html",
      },
      {
        label: "Runbook 02a — baseURL discipline and proof",
        href: "runbooks/runbook-02a-base-url-discipline.html",
      },
    ],
    video: { label: "Sprint 2 demo", youtubeId: null },
  },
  {
    num: 3,
    status: "done",
    title: "CI diagnosability (artifacts-first)",
    proof: "Every failure is explainable from artifacts alone.",
    deliverable: "GitLab pipeline publishes report/screenshots/videos/traces.",
    runbooks: [
      {
        label: "Runbook 03 — Diagnosability via Intentional Failure",
        href: "runbooks/runbook-03-diagnosability-intentional-failure.html",
      },
    ],
    video: { label: "Sprint 3 demo", youtubeId: null },
  },
  {
    num: 4,
    status: "done",
    title: "Flake taxonomy + guardrails",
    proof: "Flakes get classified and eliminated with principled fixes.",
    deliverable: "Taxonomy + at least one flake removed without timeouts.",
    runbooks: [
      {
        label: "Runbook 04 — CI artifacts + “debug without rerun”",
        href: "runbooks/runbook-04-ci-artifacts.html",
      },
      {
        label: "Sprint 4 Runbook — NAT + Port Forwarding Mode",
        href: "runbooks/runbook-04-nat-mode-explained.html",
      },
    ],
    video: { label: "Sprint 4 demo", youtubeId: null },
  },
  {
    num: 5,
    status: "done",
    title: "Test data + state reset",
    proof: "Runs are repeatable, idempotent, and parallel-friendly.",
    deliverable: "Seed/reset strategy + independent tests.",
    runbooks: [
      {
        label: "Runbook 05 — Test data + state reset",
        href: "runbooks/runbook-05-test-data-state-reset.html",
      },
    ],
    video: { label: "Sprint 5 demo", youtubeId: null },
  },
  {
    num: 6,
    title: "Time-to-signal + release gates",
    proof: "Quality gates map to risk, not coverage vanity.",
    deliverable: "Smoke vs regression + explicit go/no-go criteria (BLOCK vs WARN).",
    runbooks: [
      {
        label: "Runbook 06 — Time-to-signal + release gates",
        href: "runbooks/runbook-06-time-to-signal.html",
      },
      {
        label: "Runbook 07 — Custom fixtures (UI + API) + composition rules",
        href: "runbooks/runbook-07-custom-fixtures.html",
      },
    ],
    video: { label: "Sprint 6 demo", youtubeId: null },
    ac: [
      "Smoke gate provides fast time-to-signal",
      "Each gate declares capability/persona/impact/owner",
      "Release decision is explicit (BLOCK or WARN) per gate",
      "Failure prints the Release Gate Failure Contract without reruns",
      "Artifacts + logs are sufficient to diagnose",
    ],
  },
  {
    num: 7,
    title: "Custom fixtures (domain primitives)",
    proof:
      "Tests read like business actions; auth, API helpers, and evidence are consistent and reusable.",
    deliverable:
      "Two custom fixtures (UI + API) + fixture composition guide (worker vs test scope).",
    runbooks: [
      {
        label: "Runbook 07 — Custom fixtures (UI + API)",
        href: "runbooks/runbook-07-custom-fixtures.html",
      },
    ],
    video: { label: "Sprint 7 demo", youtubeId: null },
  },
  {
    num: 8,
    title: "Page Objects at scale (POM + utilities)",
    proof:
      "UI automation stays maintainable at 50–200+ tests with stable locator strategy and flows.",
    deliverable:
      "Scaled POM structure (pages/components/flows) + standards + add-a-new-page recipe.",
    runbooks: [
      {
        label: "Runbook 08 — Page Objects at scale",
        href: "runbooks/runbook-08-pom-at-scale.html",
      },
    ],
    video: { label: "Sprint 8 demo", youtubeId: null },
  },
];

const personas = [
  {
    title: "CI Architect",
    mission: "Make pipelines boring and trustworthy.",
    outputs: [
      "MR pipeline always runs",
      "Artifacts always available",
      "Promotion path dev → qa → stage",
    ],
    rules: [
      "No manual steps except deliberate approvals",
      "Failures diagnosable from artifacts alone",
    ],
  },
  {
    title: "Flake Detective",
    mission: "Reduce noise without hiding risk.",
    outputs: [
      "Flake taxonomy",
      "At least one principled flake elimination per cycle",
    ],
    rules: [
      "No waitForTimeout as a fix",
      "Don’t increase timeouts until the failure mode is explained",
    ],
  },
  {
    title: "Release Gatekeeper",
    mission: "Prevent silent regressions from shipping.",
    outputs: ["Minimal go/no-go suite", "Rationale mapping tests → risks"],
    rules: ["Every gate maps to a risk", "Coverage ≠ safety to ship"],
  },
  {
    title: "New Hire",
    mission: "Make the system understandable in 30 minutes.",
    outputs: ["One-page setup", "Top 10 troubleshooting failures"],
    rules: [
      "If it’s not documented, it doesn’t exist",
      "No tribal knowledge dependencies",
    ],
  },
];

const publicVsPrivate = {
  safe: [
    "Architecture patterns (runner → SUT)",
    "Environment layout and conventions (dev/qa/stage)",
    "baseURL via env vars (pattern + reasoning)",
    "Runbooks with sanitized examples",
    "Lessons learned and postmortems (sanitized)",
    "Reports/screenshots with secrets removed",
  ],
  private: [
    "Public IPs, ISP DNS values, router model details",
    "SSH/VNC endpoints and exposed ports",
    "Runner registration tokens / deploy keys",
    "Exact firewall rules that fingerprint home LAN",
    "Credentials, API keys, or anything exploitable",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{site.title}</title>
    <meta name="description" content={site.tagline} />
    <style>
      /* Your existing styles unchanged — keeping them exactly as-is */
      :root {
        --bg: #0b0e14;
        --panel: #121827;
        --text: #e6e9ef;
        --muted: #aab2c5;
        --link: #7aa2ff;
        --border: #24304d;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
        background: var(--bg);
        color: var(--text);
      }
      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .wrap { max-width: 1100px; margin: 0 auto; padding: 20px 18px 54px; }
      .nav {
        position: sticky; top: 0; z-index: 20;
        backdrop-filter: blur(10px);
        background: rgba(11, 14, 20, 0.78);
        border-bottom: 1px solid var(--border);
        padding: 12px 0;
      }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
      .brand { font-weight: 750; letter-spacing: 0.2px; }
      .navlinks { display: flex; gap: 14px; flex-wrap: wrap; font-size: 14px; }
      .pill {
        display: inline-block;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.04);
        padding: 7px 10px;
        border-radius: 999px;
      }
      section { scroll-margin-top: 84px; }
      .hero { padding: 26px 0 10px; }
      .h1 { font-size: 40px; line-height: 1.1; margin: 0 0 10px; letter-spacing: -0.6px; }
      .lead { color: var(--muted); font-size: 16px; line-height: 1.6; max-width: 850px; }
      .row { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 14px; }
      .cta { border: 1px solid var(--border); background: var(--panel); padding: 12px 14px; border-radius: 14px; }
      .cta strong { display: block; margin-bottom: 4px; }
      .grid { display: grid; gap: 14px; }
      .grid2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .grid3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 18px;
        margin-top: 14px;
        box-shadow: 0 0 0 1px rgba(255,255,255,0.02);
      }
      .muted { color: var(--muted); }
      h2 { margin: 0 0 10px; font-size: 22px; }
      h3 { margin: 0 0 10px; font-size: 16px; }
      ul { margin: 10px 0 0 18px; color: var(--text); }
      li { margin: 6px 0; color: var(--muted); }
      .kpi { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
      .kpi span {
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 6px 10px;
        color: var(--muted);
        background: rgba(255, 255, 255, 0.03);
        font-size: 13px;
      }
      .divider { height: 1px; background: var(--border); margin: 22px 0; }
      .video iframe { border-radius: 12px; border: 1px solid var(--border); }
      .mini { font-size: 13px; color: var(--muted); }
      .table { width: 100%; border-collapse: collapse; margin-top: 10px; }
      .table td { border-top: 1px solid var(--border); padding: 10px 6px; vertical-align: top; }
      .table td:first-child { color: var(--muted); width: 160px; }
      footer {
        margin-top: 30px; padding-top: 16px;
        border-top: 1px solid var(--border);
        color: var(--muted); font-size: 14px;
      }
      @media (max-width: 920px) {
        .grid2, .grid3 { grid-template-columns: 1fr; }
        .h1 { font-size: 32px; }
      }
    </style>
  </head>

  <body>
    <div class="nav">
      <div class="wrap">
        <div class="nav-inner">
          <div class="brand">{site.title}</div>
          <div class="navlinks">
            <a class="pill" href="#start-here">Start Here</a>
            <a class="pill" href="#about">About</a>
            <a class="pill" href="#architecture">Architecture</a>
            <a class="pill" href="#sprints">Sprint Plan</a>
            <a class="pill" href="#personas">Personas</a>
            <a class="pill" href="#runbooks">Runbooks</a>
            <a class="pill" href="#public-private">Public vs Private</a>
          </div>
        </div>
      </div>
    </div>

    <div class="wrap">
      <!-- HERO -->
      <section class="hero" id="start-here">
        <div class="h1">A Living QA Test Lab</div>

        <p class="lead">
          A production-realistic QA test lab designed to practice automation,
          CI, and release discipline under real constraints—without enterprise
          overhead.
        </p>

        <div class="card" style="margin-top:14px;">
          <h2 style="margin-bottom:8px;">30-second review</h2>

          <div class="grid grid3" style="margin-top:10px;">
            <div>
              <h3>What this is</h3>
              <p class="muted" style="margin:0;">
                A production-realistic QA test lab that separates <strong>CI runner</strong>
                and <strong>SUT host</strong>, deploys environments via Docker
                Compose, and validates releases through CI gates—built for hands-on practice
                without enterprise overhead.
              </p>
              <p class="mini" style="margin-top:10px;">
                I built this because I got tired of “it works on my machine” being the default excuse.
              </p>
            </div>

            <div>
              <h3>What proof exists today</h3>
              <ul style="margin:8px 0 0 18px;">
                <li>CI runner → SUT host network boundary (no localhost shortcuts)</li>
                <li>
                  Stable hostnames (<code>sut.testlab</code>) and env contract via
                  <code>WEB_BASE_URL</code> / <code>API_BASE_URL</code>
                </li>
                <li>
                  Live SUT deployed via Docker Compose (dev) and reachable by name
                </li>
              </ul>
              <p class="mini" style="margin-top:10px;">
                Lesson: anything that only works on localhost dies the first time CI touches it.
              </p>
            </div>

            <div>
              <h3>Fast path (Sprint 0–3)</h3>
              <ul style="margin:8px 0 0 18px;">
                <li><a href="#sprints">Sprint 0:</a> Golden VM baseline + rollback</li>
                <li><a href="#sprints">Sprint 1:</a> Topology baseline (CI runner → SUT)</li>
                <li><a href="#sprints">Sprint 2:</a> baseURL discipline (env-driven navigation)</li>
                <li><a href="#sprints">Sprint 3:</a> Diagnosability via intentional failure</li>
              </ul>
              <p class="mini" style="margin-top:10px;">
                If you’re skimming: Sprint 0–3, then Architecture.
              </p>
            </div>
          </div>
        </div>
      </section>

      <div class="row">
        <div class="cta">
          <strong>What this shows</strong>
          <div class="mini">
            How CI signals, failure diagnosis, and release decisions behave under realistic constraints.
          </div>
        </div>
        <div class="cta">
          <strong>What this is not</strong>
          <div class="mini">
            This isn’t another localhost demo — those fall apart the second you introduce CI and a separate machine.
          </div>
        </div>
        <div class="cta">
          <strong>Videos</strong>
          <div class="mini">
            Sprint clips get added as they’re recorded.
          </div>
        </div>
      </div>

      <div class="kpi">
        <span>CI runner → SUT boundary</span>
        <span>Docker Compose environments</span>
        <span>GitLab CI artifacts</span>
        <span>Flake taxonomy</span>
        <span>Idempotent test runs</span>
        <span>Risk-based gates</span>
      </div>
    </div>

    <div class="divider"></div>

    <!-- ABOUT -->
    <section id="about">
      <div class="wrap">
        <h2>About</h2>
        <div class="grid grid2" style="margin-top:14px;">
          <div class="card">
            <h3>What this lab is</h3>
            <p class="muted">
              QA Test Lab is a production-realistic environment built to stay current with modern automation,
              CI/CD, and test infrastructure—without the cost or operational overhead of full enterprise systems.
              It’s designed to surface the failure modes people usually hide (by accident) with localhost shortcuts.
            </p>
            <p class="mini" style="margin-top:10px;">
              This keeps tests reliable when CI actually runs them.
            </p>
            <div class="kpi" style="margin-top:12px;">
              <span>Production-real topology</span>
              <span>Env-driven config</span>
              <span>Artifacts-first CI</span>
              <span>Risk-based gates</span>
            </div>
          </div>

          <div class="card">
            <h3>How it’s run</h3>
            <p class="muted">
              Each sprint ships a concrete capability plus a runbook that documents setup, validation,
              and the failure modes you actually see in real pipelines.
            </p>
            <p class="mini" style="margin-top:10px;">
              Lesson: if a system relies on tribal knowledge, it breaks when the person leaves.
            </p>
            <p class="mini" style="margin-top:10px;">
              If it’s not documented, it doesn’t exist.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ARCHITECTURE -->
    <section id="architecture">
      <div class="wrap">
        <h2>Architecture (Production-Real Baseline)</h2>
        <div class="grid grid2">
          <div class="card">
            <h3>Core idea</h3>
            <p class="muted">
              CI runs from a dedicated runner and targets a SUT hosted on a separate machine boundary.
              The SUT host also supports local Playwright runs for recording and debugging, but CI is the proof:
              it must cross the boundary (CI runner → SUT host).
            </p>

            <table class="table">
              <tr><td>CI Runner</td><td>New Mac mini running GitLab Runner pipeline jobs</td></tr>
              <tr><td>SUT Host</td><td>MacBook Pro hosting Ubuntu VM + Docker Compose (web + api + db)</td></tr>
              <tr><td>Local Runner</td><td>MacBook Pro also runs Playwright interactively (debug/recording)</td></tr>
              <tr><td>DNS</td><td>Stable hostnames via <code>/etc/hosts</code> (e.g., <code>sut.testlab</code>)</td></tr>
              <tr><td>Config</td><td><code>WEB_BASE_URL</code>/<code>API_BASE_URL</code> drive navigation and API calls (no hardcoded domains)</td></tr>
            </table>

            <p class="mini" style="margin-top:10px;">
              Lesson: if naming and env config aren’t boring, documented and consistent, debugging turns into archaeology.
            </p>
          </div>

          <div class="card">
            <h3>Reference diagram (text)</h3>
            <p class="muted">Quick topology sketch:</p>
            <pre style="margin:0; white-space:pre; color:var(--muted); background:rgba(255,255,255,.03); border:1px solid var(--border); padding:14px; border-radius:12px;">
[GitLab CI Runner / Mac mini]
        |
        |  Playwright tests (WEB_BASE_URL / API_BASE_URL)
        v
[SUT Host / MacBook Pro]
  Ubuntu VM (VirtualBox)
   Docker Compose:
    - web  -> :3000
    - api  -> :3001
    - db   -> internal
            </pre>
            <p class="mini" style="margin-top:10px;">
              This is the shape that keeps me honest: if CI can’t reach it by name, it doesn’t count as “working.”
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- SPRINTS -->
    <section id="sprints">
      <div class="wrap">
        <h2>First 8 Sprints</h2>
        <p class="muted">
          The sprint sequence is intentional: topology realism, environment discipline, CI diagnosability,
          flake elimination, data/state control, risk-based release gates, fixture composition,
          and scalable page object design.
        </p>

        <p class="mini" style="margin-top:10px;">
          I picked it based on the failures I’ve seen teams hit over and over.
        </p>

        <div class="grid grid2" style="margin-top:14px;">
          {
            sprintHighlights.map((s) => (
              <div class="card">
                <div style="display:flex; align-items:baseline; justify-content:space-between; gap:12px;">
                  <h3 style="margin:0;">Sprint {s.num}: {s.title}</h3>

                  {s.status ? (
                    <span class="pill" style="font-size:12px; padding:6px 10px;" title={`Status: ${s.status}`}>
                      {String(s.status).toUpperCase()}
                    </span>
                  ) : null}
                </div>

                <p class="muted" style="margin-top:10px;">
                  <strong>What it proves:</strong> {s.proof}
                </p>

                <p class="muted">
                  <strong>Deliverable:</strong> {s.deliverable}
                </p>

                {s.runbooks?.length ? (
                  <>
                    <p class="muted" style="margin-top:10px;">
                      <strong>Runbooks:</strong>
                    </p>
                    <ul style="margin:6px 0 0 18px;">
                      {s.runbooks.map((rb) => (
                        <li><a href={rb.href}>{rb.label}</a></li>
                      ))}
                    </ul>
                  </>
                ) : null}

                {/* Video embeds only show when a real YouTube ID exists */}
                {s.video?.youtubeId ? (
                  <div class="video" style="margin-top:12px;">
                    <iframe
                      width="100%"
                      height="420"
                      src={`https://www.youtube.com/embed/${s.video.youtubeId}`}
                      title={s.video.label}
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    />
                  </div>
                ) : null}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- PERSONAS -->
    <section id="personas">
      <div class="wrap">
        <h2>Personas (Deliberate Practice Roles)</h2>
        <p class="muted">
          Personas apply real pressure: pipeline design, flake elimination, release risk thinking,
          and onboarding clarity. Each one pulls on a different maturity muscle.
        </p>

        <p class="mini" style="margin-top:10px;">
          I’ve seen teams collapse because nobody “owned” the boring parts. Personas make ownership visible.
        </p>

        <div class="grid grid2" style="margin-top:14px;">
          {
            personas.map((p) => (
              <div class="card">
                <h3>{p.title}</h3>
                <p class="muted"><strong>Mission:</strong> {p.mission}</p>

                <p style="margin-top:10px;"><strong>Outputs</strong></p>
                <ul>{p.outputs.map((o) => (<li>{o}</li>))}</ul>

                <p style="margin-top:10px;"><strong>Rules</strong></p>
                <ul>{p.rules.map((r) => (<li>{r}</li>))}</ul>

                <p class="mini" style="margin-top:10px;">
                  Quick tip: print this page to PDF if you want persona cards you can keep open during work.
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- RUNBOOKS -->
    <section id="runbooks">
      <div class="wrap">
        <h2>Runbooks</h2>
        <div class="grid grid2" style="margin-top:14px;">
          <div class="card">
            <h3>What each runbook includes</h3>
            <p class="muted">
              Each runbook has the goal, exact commands, what the output should look like,
              how things usually break, and why I bothered building it this way.
            </p>
            <p class="mini" style="margin-top:10px;">
              Lesson: “we’ll remember how to do it” is the fastest path to repeated outages and reruns.
            </p>
          </div>

          <div class="card">
            <h3>Runbooks</h3>
            <ul>
              <li>
                <a href="runbooks/runbook-00-golden-vm-baseline.html">
                  Runbook 00 — Golden VM baseline (Ubuntu Server + SSH keys + snapshot)
                </a>
              </li>
              <li>
                <a href="runbooks/runbook-01-runner-to-sut.html">
                  Runbook 01 — Runner → SUT connectivity and naming
                </a>
              </li>
              <li>
                <a href="runbooks/runbook-02-compose-deploy.html">
                  Runbook 02 — Compose deploy (dev) + health check
                </a>
              </li>
              <li>
                <a href="runbooks/runbook-02a-base-url-discipline.html">
                  Runbook 02a — baseURL discipline and proof
                </a>
              </li>
              <li>
                <a href="runbooks/runbook-03-diagnosability-intentional-failure.html">
                  Runbook 03 — Diagnosability via Intentional Failure
                </a>
              </li>
              <li>
                <a href="runbooks/runbook-04-ci-artifacts.html">
                  Runbook 04 — CI artifacts + “debug without rerun”
                </a>
              </li>
              <li>
                <a href="runbooks/runbook-04-nat-mode-explained.html">
                  Sprint 4 Runbook — NAT + Port Forwarding Mode
                </a>
              </li>
              <li>
                <a href="runbooks/runbook-05-test-data-state-reset.html">
                  Runbook 05 — Test data + state reset (API-seeded, idempotent runs)
                </a>
              </li>
              <li>
                <a href="runbooks/runbook-06-time-to-signal.html">
                  Runbook 06 — Time-to-signal + release gates
                </a>
              </li>
              <li>
                <a href="runbooks/runbook-07-custom-fixtures.html">
                  Runbook 07 — Custom fixtures (UI + API) + composition rules
                </a>

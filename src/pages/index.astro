    <style>
      :root {
        --bg: #0b0e14;
        --panel: #121827;
        --text: #e6e9ef;
        --muted: #aab2c5;
        --link: #7aa2ff;
        --border: #24304d;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
        background: var(--bg);
        color: var(--text);
      }
      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .wrap { max-width: 1100px; margin: 0 auto; padding: 20px 18px 54px; }
      .nav {
        position: sticky; top: 0; z-index: 20;
        backdrop-filter: blur(10px);
        background: rgba(11, 14, 20, 0.78);
        border-bottom: 1px solid var(--border);
        padding: 12px 0;
      }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
      .brand { font-weight: 750; letter-spacing: 0.2px; }
      .navlinks { display: flex; gap: 14px; flex-wrap: wrap; font-size: 14px; }
      .pill {
        display: inline-block;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.04);
        padding: 7px 10px;
        border-radius: 999px;
      }
      section { scroll-margin-top: 84px; }
      .hero { padding: 26px 0 10px; }
      .h1 { font-size: 40px; line-height: 1.1; margin: 0 0 10px; letter-spacing: -0.6px; }
      .lead { color: var(--muted); font-size: 16px; line-height: 1.6; max-width: 850px; }
      .row { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 14px; }
      .cta { border: 1px solid var(--border); background: var(--panel); padding: 12px 14px; border-radius: 14px; }
      .cta strong { display: block; margin-bottom: 4px; }
      .grid { display: grid; gap: 14px; }
      .grid2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .grid3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 18px;
        margin-top: 14px;
        box-shadow: 0 0 0 1px rgba(255,255,255,0.02);
      }
      .muted { color: var(--muted); }
      h2 { margin: 0 0 10px; font-size: 22px; }
      h3 { margin: 0 0 10px; font-size: 16px; }
      ul { margin: 10px 0 0 18px; color: var(--text); }
      li { margin: 6px 0; color: var(--muted); }
      .kpi { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
      .kpi span {
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 6px 10px;
        color: var(--muted);
        background: rgba(255, 255, 255, 0.03);
        font-size: 13px;
      }
      .divider { height: 1px; background: var(--border); margin: 22px 0; }
      .video iframe { border-radius: 12px; border: 1px solid var(--border); }
      .mini { font-size: 13px; color: var(--muted); }
      .table { width: 100%; border-collapse: collapse; margin-top: 10px; }
      .table td { border-top: 1px solid var(--border); padding: 10px 6px; vertical-align: top; }
      .table td:first-child { color: var(--muted); width: 160px; }
      footer {
        margin-top: 30px; padding-top: 16px;
        border-top: 1px solid var(--border);
        color: var(--muted); font-size: 14px;
      }
      @media (max-width: 920px) {
        .grid2, .grid3 { grid-template-columns: 1fr; }
        .h1 { font-size: 32px; }
      }
    </style>
  </head>


---
const pageTitle = 'Choose Your Next Step';
const pageDescription =
  "Choose how you’d like to continue. Book a consultation or submit a question below, and we’ll help you move forward.";

const consultationHref = "/contact/";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <style>
      :root {
        --bg: #0b1020;
        --panel: rgba(255, 255, 255, 0.06);
        --panel-border: rgba(255, 255, 255, 0.12);
        --text: #f5f7fb;
        --muted: #b8c0d4;
        --accent: #5b5cf0;
        --accent-hover: #4b4ce0;
        --input-bg: rgba(255, 255, 255, 0.04);
        --success-bg: rgba(91, 92, 240, 0.14);
        --success-border: rgba(110, 231, 183, 0.25);
        --success-panel: rgba(110, 231, 183, 0.08);
        --error-bg: rgba(239, 68, 68, 0.12);
        --error-border: rgba(239, 68, 68, 0.22);
        --error-text: #fecaca;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background:
          radial-gradient(circle at top left, rgba(91, 92, 240, 0.22), transparent 30%),
          linear-gradient(180deg, #0b1020 0%, #11182d 100%);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        min-height: 100%;
      }

      .wrap {
        max-width: 980px;
        margin: 0 auto;
        padding: 56px 20px 80px;
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 22px;
        padding: 34px;
        backdrop-filter: blur(10px);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
      }

      .brand-lockup {
        display: flex;
        justify-content: center;
        margin-bottom: 18px;
      }

      .brand-lockup a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .brand-logo {
        display: block;
        max-width: 220px;
        width: 100%;
        height: auto;
        max-height: 72px;
        object-fit: contain;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--success-bg);
        color: #d9dcff;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: 0.02em;
        margin-bottom: 20px;
      }

      h1 {
        margin: 0 0 14px;
        font-size: clamp(38px, 6vw, 58px);
        line-height: 1.02;
      }

      .subtext {
        margin: 0 0 32px;
        color: var(--muted);
        font-size: 19px;
        line-height: 1.6;
        max-width: 760px;
      }

      .option-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
      }

      .option-card {
        background: rgba(255, 255, 255, 0.035);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 18px;
        padding: 26px;
        min-height: 100%;
      }

      .icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(91, 92, 240, 0.18);
        border: 1px solid rgba(91, 92, 240, 0.45);
        color: #cbd2ff;
        font-size: 24px;
        margin-bottom: 18px;
      }

      h2 {
        margin: 0 0 10px;
        font-size: 26px;
        line-height: 1.15;
      }

      .option-copy {
        margin: 0 0 22px;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.6;
      }

      .benefits {
        list-style: none;
        padding: 0;
        margin: 0 0 24px;
        display: grid;
        gap: 12px;
        color: var(--muted);
      }

      .benefits li {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .dot {
        width: 28px;
        height: 28px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
        background: rgba(91, 92, 240, 0.18);
        color: #cbd2ff;
        font-size: 14px;
      }

      .button,
      button {
        appearance: none;
        width: 100%;
        border: 0;
        border-radius: 12px;
        background: var(--accent);
        color: white;
        font-size: 16px;
        font-weight: 800;
        padding: 15px 18px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: background 0.2s ease, opacity 0.2s ease;
      }

      .button:hover,
      button:hover {
        background: var(--accent-hover);
      }

      button:disabled {
        opacity: 0.7;
        cursor: wait;
      }

      form {
        display: grid;
        gap: 14px;
      }

      label {
        display: block;
        font-size: 14px;
        font-weight: 800;
        margin-bottom: 7px;
      }

      input,
      textarea {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: var(--input-bg);
        color: var(--text);
        border-radius: 12px;
        padding: 13px 15px;
        font-size: 15px;
        outline: none;
      }

      input::placeholder,
      textarea::placeholder {
        color: #8f99b2;
      }

      input:focus,
      textarea:focus {
        border-color: rgba(91, 92, 240, 0.9);
        box-shadow: 0 0 0 3px rgba(91, 92, 240, 0.18);
      }

      textarea {
        min-height: 132px;
        resize: vertical;
      }

      .required {
        color: #cbd2ff;
      }

      .status {
        display: none;
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 14px;
        line-height: 1.6;
      }

      .status.show {
        display: block;
      }

      .status.success {
        background: var(--success-panel);
        border: 1px solid var(--success-border);
        color: #d1fae5;
      }

      .status.error {
        background: var(--error-bg);
        border: 1px solid var(--error-border);
        color: var(--error-text);
      }

      .success-card {
        display: none;
        margin-top: 8px;
        background: var(--success-panel);
        border: 1px solid var(--success-border);
        border-radius: 16px;
        padding: 18px;
      }

      .success-card.show {
        display: block;
      }

      .success-card h3 {
        margin: 0 0 8px;
        font-size: 20px;
      }

      .success-card p {
        margin: 0;
        color: #d1fae5;
        line-height: 1.7;
      }

      .hidden-on-success.hide {
        display: none;
      }

      .privacy {
        margin: 28px 0 0;
        color: var(--muted);
        font-size: 15px;
        text-align: center;
      }

      @media (max-width: 840px) {
        .option-grid {
          grid-template-columns: 1fr;
        }

        .card {
          padding: 24px;
        }
      }
    </style>
  </head>

  <body>
    <main class="wrap">
      <section class="card">
        <div class="brand-lockup">
          <a href="/" aria-label="QA ALIGN home">
            <img
              src="/qa-align-logo.png"
              alt="QA ALIGN"
              class="brand-logo"
            />
          </a>
        </div>

        <div class="eyebrow">✓ You're in</div>

        <h1>{pageTitle}</h1>

        <p class="subtext">
          {pageDescription}
        </p>

        <div class="option-grid">
          <section class="option-card" aria-labelledby="consultation-title">
            <div class="icon" aria-hidden="true">📅</div>

            <h2 id="consultation-title">Book a Consultation</h2>

            <p class="option-copy">
              Schedule a consultation to walk through your framework, discuss reliability risks,
              and plan the next steps together.
            </p>

            <ul class="benefits">
              <li><span class="dot">▶</span>Live conversation</li>
              <li><span class="dot">👥</span>Discuss your setup</li>
              <li><span class="dot">➤</span>Get guidance on next steps</li>
            </ul>

            <a class="button" href={consultationHref}>
              Book Consultation →
            </a>
          </section>

          <section class="option-card" aria-labelledby="question-title">
            <div class="icon" aria-hidden="true">?</div>

            <h2 id="question-title">Submit a Question</h2>

            <p class="option-copy">
              Send a question or concern about your framework and we’ll review it as part
              of the assessment process.
            </p>

            <form
              id="question-form"
              action="https://formspree.io/f/mlgajonk"
              method="POST"
            >
              <div class="hidden-on-success" id="question-fields">
                <div>
                  <label for="email">Email <span class="required">*</span></label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    autocomplete="email"
                    placeholder="you@company.com"
                  />
                </div>

                <div>
                  <label for="question">Question <span class="required">*</span></label>
                  <textarea
                    id="question"
                    name="question"
                    required
                    placeholder="What would you like us to review or answer?"
                  ></textarea>
                </div>

                <input type="hidden" name="source" value="qa-align-thank-you-question" />
                <input type="hidden" name="product" value="automation-assessment" />

                <button id="submit-button" type="submit">
                  Submit Question →
                </button>

                <div id="form-status" class="status" aria-live="polite"></div>
              </div>

              <div id="success-card" class="success-card" aria-live="polite">
                <h3>Question received.</h3>
                <p>
                  We’ve received your question. We’ll review it and follow up by email.
                </p>
              </div>
            </form>
          </section>
        </div>

        <p class="privacy">
          🔒 Secure. Private. Your information is only used for this assessment.
        </p>
      </section>
    </main>

    <script>
      const form = document.getElementById('question-form') as HTMLFormElement | null;
      const submitButton = document.getElementById('submit-button') as HTMLButtonElement | null;
      const formStatus = document.getElementById('form-status') as HTMLDivElement | null;
      const formFields = document.getElementById('question-fields') as HTMLDivElement | null;
      const successCard = document.getElementById('success-card') as HTMLDivElement | null;

      function showStatus(message: string, type: 'success' | 'error') {
        if (!formStatus) return;
        formStatus.textContent = message;
        formStatus.className = `status show ${type}`;
      }

      if (form && submitButton && formFields && successCard) {
        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          submitButton.disabled = true;
          submitButton.textContent = 'Submitting...';

          if (formStatus) {
            formStatus.className = 'status';
            formStatus.textContent = '';
          }

          try {
            const response = await fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: {
                Accept: 'application/json',
              },
            });

            if (response.ok) {
              formFields.classList.add('hide');
              successCard.classList.add('show');
              form.reset();
              return;
            }

            let errorMessage = 'Submission failed. Please try again.';
            try {
              const data = await response.json();
              if (
                data &&
                Array.isArray(data.errors) &&
                data.errors.length > 0 &&
                data.errors[0]?.message
              ) {
                errorMessage = data.errors[0].message;
              }
            } catch (_) {
              // keep fallback message
            }

            showStatus(errorMessage, 'error');
          } catch (_) {
            showStatus('Network error. Please try again.', 'error');
          } finally {
            submitButton.disabled = false;
            submitButton.textContent = 'Submit Question →';
          }
        });
      }

      window.addEventListener('load', function () {
        if (typeof gtag === 'function') {
          gtag('event', 'conversion', {
            send_to: 'AW-18107787011/PxTyCOWX9qUcEIP0u7pD'
          });

          console.log("QA ALIGN thank-you lead conversion fired");
        }
      });
    </script>
  </body>
</html>

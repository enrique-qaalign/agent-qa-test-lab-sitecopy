---
const pageTitle = 'Submit Your Automation for Assessment';
const pageDescription =
  'Your payment is confirmed. Submit your framework or repository below to begin your assessment.';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <style>
      :root {
        --bg: #0b1020;
        --panel: rgba(255, 255, 255, 0.06);
        --panel-border: rgba(255, 255, 255, 0.12);
        --text: #f5f7fb;
        --muted: #b8c0d4;
        --accent: #5b5cf0;
        --accent-hover: #4b4ce0;
        --input-bg: rgba(255, 255, 255, 0.04);
        --success-bg: rgba(91, 92, 240, 0.14);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background:
          radial-gradient(circle at top left, rgba(91, 92, 240, 0.22), transparent 30%),
          linear-gradient(180deg, #0b1020 0%, #11182d 100%);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        min-height: 100%;
      }

      .wrap {
        max-width: 860px;
        margin: 0 auto;
        padding: 56px 20px 80px;
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 20px;
        padding: 32px;
        backdrop-filter: blur(10px);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--success-bg);
        color: #d9dcff;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.02em;
        margin-bottom: 20px;
      }

      h1 {
        margin: 0 0 14px;
        font-size: clamp(32px, 5vw, 48px);
        line-height: 1.05;
      }

      .subtext {
        margin: 0 0 28px;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.6;
        max-width: 680px;
      }

      .grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 28px;
        margin-top: 28px;
      }

      .panel {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 18px;
        padding: 24px;
      }

      h2 {
        margin: 0 0 16px;
        font-size: 22px;
      }

      .steps {
        margin: 0;
        padding-left: 20px;
        color: var(--muted);
        line-height: 1.7;
      }

      .steps li + li {
        margin-top: 8px;
      }

      form {
        display: grid;
        gap: 16px;
      }

      label {
        display: block;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 8px;
      }

      .required {
        color: #cbd2ff;
      }

      input,
      textarea {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: var(--input-bg);
        color: var(--text);
        border-radius: 12px;
        padding: 14px 16px;
        font-size: 16px;
        outline: none;
      }

      input::placeholder,
      textarea::placeholder {
        color: #8f99b2;
      }

      input:focus,
      textarea:focus {
        border-color: rgba(91, 92, 240, 0.9);
        box-shadow: 0 0 0 3px rgba(91, 92, 240, 0.18);
      }

      textarea {
        min-height: 140px;
        resize: vertical;
      }

      .helper {
        margin-top: 6px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
      }

      .button {
        appearance: none;
        border: 0;
        border-radius: 12px;
        background: var(--accent);
        color: white;
        font-size: 16px;
        font-weight: 700;
        padding: 15px 18px;
        cursor: pointer;
        transition: background 0.2s ease;
      }

      .button:hover {
        background: var(--accent-hover);
      }

      .note {
        margin-top: 12px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
      }

      .small {
        color: var(--muted);
        font-size: 14px;
        line-height: 1.6;
      }

      .divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.08);
        margin: 26px 0;
      }

      @media (max-width: 840px) {
        .grid {
          grid-template-columns: 1fr;
        }

        .card {
          padding: 24px;
        }
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="card">
        <div class="eyebrow">Payment confirmed</div>
        <h1>{pageTitle}</h1>
        <p class="subtext">
          {pageDescription} You’ll receive your report within 24–48 hours after
          submission.
        </p>

        <div class="grid">
          <div class="panel">
            <h2>Assessment Intake</h2>

            <!-- Replace the form action with your Formspree / Basin / webhook URL -->
            <form
              action="https://formspree.io/f/mlgajonk"
              method="POST"
            >
              <div>
                <label for="email">Email <span class="required">*</span></label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                  placeholder="you@company.com"
                />
              </div>

              <div>
                <label for="repoUrl">Repository URL <span class="required">*</span></label>
                <input
                  id="repoUrl"
                  name="repoUrl"
                  type="url"
                  required
                  placeholder="https://github.com/your-org/your-repo"
                />
                <div class="helper">
                  GitHub, GitLab, Bitbucket, or other repository link.
                </div>
              </div>

              <div>
                <label for="siteUrl">Site URL</label>
                <input
                  id="siteUrl"
                  name="siteUrl"
                  type="url"
                  placeholder="https://app.yourcompany.com"
                />
              </div>

              <div>
                <label for="notes">Notes</label>
                <textarea
                  id="notes"
                  name="notes"
                  placeholder="Anything we should know before reviewing your framework?"
                ></textarea>
              </div>

              <input type="hidden" name="source" value="stripe-thank-you-page" />

              <button class="button" type="submit">Submit for Analysis</button>

              <p class="note">
                This form should send to your email or webhook. Replace the
                placeholder action URL before deploying.
              </p>
            </form>
          </div>

          <aside class="panel">
            <h2>What happens next</h2>
            <ol class="steps">
              <li>We review your framework or repository.</li>
              <li>We identify the top reliability and diagnosability issues.</li>
              <li>We estimate the effort and cost to fix them.</li>
              <li>We deliver your assessment report by email.</li>
            </ol>

            <div class="divider"></div>

            <p class="small">
              Deliverable includes trust level, issue breakdown, occurrence
              counts, and estimated fix cost.
            </p>
          </aside>
        </div>
      </section>
    </main>
  </body>
</html>
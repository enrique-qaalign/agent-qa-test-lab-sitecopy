      <section id="priority" class="card">
        <h2>Locator priority model</h2>
        <table class="table">
          <tr>
            <td>Priority 1</td>
            <td><code>getByRole(role, { name })</code></td>
          </tr>
          <tr>
            <td>Priority 2</td>
            <td><code>getByLabel()</code></td>
          </tr>
          <tr>
            <td>Priority 3</td>
            <td><code>getByPlaceholder()</code></td>
          </tr>
          <tr>
            <td>Priority 4</td>
            <td><code>getByText()</code> only when stable and semantically anchored</td>
          </tr>
          <tr>
            <td>Last resort</td>
            <td>CSS/XPath, explicitly flagged as higher risk</td>
          </tr>
        </table>

        <div class="callout">
          <span class="tag">Risk model</span>
          <ul style="margin:8px 0 0 18px;">
            <li><strong>LOW:</strong> unique role + unique accessible name</li>
            <li><strong>MEDIUM:</strong> stable semantics but repeated names or dynamic text dependence</li>
            <li><strong>HIGH:</strong> index-based, CSS chain, or missing accessibility semantics</li>
          </ul>
        </div>
      </section>
      
      <section id="mechanics" class="card">
        <h2>Mechanics</h2>
        <ul>
          <li>Navigate to the target route in a known state.</li>
          <li>Capture the accessibility tree.</li>
          <li>Normalize nodes by role, name, and interactive value.</li>
          <li>Generate ranked locator recommendations.</li>
          <li>Attach ambiguity and accessibility risk flags.</li>
        </ul>

        <div class="callout">
          <span class="tag">Extraction</span>
          <pre><code>const snapshot = await page.accessibility.snapshot(&#123; interestingOnly: false &#125;);</code></pre>
        </div>

        <h3 style="margin-top:14px;">Recommended output schema</h3>
        <pre><code>&#123;
  "page": "/#/editor",
  "generatedAt": "2026-03-28T10:10:00Z",
  "elements": [
    &#123;
      "role": "textbox",
      "name": "Article Title",
      "locator": "page.getByRole('textbox', &#123; name: 'Article Title' &#125;)",
      "priority": 1,
      "risk": "LOW",
      "reason": "Explicit role and accessible name are stable and user-facing."
    &#125;,
    &#123;
      "role": "button",
      "name": "Publish Article",
      "locator": "page.getByRole('button',&#125; name: 'Publish Article' &#125;",
      "priority": 1,
      "risk": "LOW",
      "reason": "Action control with unique accessible name."
    &#125;
  ],
  "risks": [
    "2 buttons share the name 'Save'",
    "1 input lacks an accessible label"
  ]
&#125;</code></pre>
      </section>


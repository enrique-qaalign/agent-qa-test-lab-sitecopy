---
import fs from 'node:fs';
import path from 'node:path';

const reportsDir = path.join(process.cwd(), 'src', 'data', 'reports');
const files = fs.existsSync(reportsDir)
  ? fs.readdirSync(reportsDir).filter((name) => name.endsWith('.json'))
  : [];

const reports = files.map((file) => {
  const fullPath = path.join(reportsDir, file);
  const data = JSON.parse(fs.readFileSync(fullPath, 'utf-8'));
  return {
    slug: data.slug,
    client_name: data.client_name,
    trust_level: data.trust_level,
    framework: data.framework
  };
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Reports</title>
    <style>
      body {
        margin: 0;
        padding: 40px 20px;
        background: #0b1020;
        color: #f5f7fb;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      .wrap {
        max-width: 900px;
        margin: 0 auto;
      }

      h1 {
        margin-top: 0;
      }

      .list {
        display: grid;
        gap: 14px;
      }

      .item {
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 14px;
        padding: 18px;
        background: rgba(255,255,255,0.04);
      }

      a {
        color: #cdd6ff;
        font-size: 20px;
        font-weight: 700;
        text-decoration: none;
      }

      .meta {
        margin-top: 8px;
        color: #b8c0d4;
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <h1>Available Reports</h1>

      <div class="list">
        {reports.map((report) => (
          <div class="item">
            <a href={`/reports/${report.slug}`}>{report.client_name}</a>
            <div class="meta">
              {report.framework} · Trust Level: {report.trust_level}
            </div>
          </div>
        ))}
      </div>
    </main>
  </body>
</html>

---
import ProblemCard from "../../components/ProblemCard.astro";


const trustMatrix = [
  {
    level: "Low Trust",
    description:
      "Tests are flaky, failures are unclear, and results are not yet safe to use for release decisions.",
    focus: "Start with diagnosability, flake elimination, and state control.",
  },
  {
    level: "Medium Trust",
    description:
      "Tests mostly work, but the system still has drift, partial confidence, or inconsistent release signal.",
    focus: "Tighten state control, formalize release gates, and improve consistency.",
  },
  {
    level: "High Trust",
    description:
      "Tests are stable, diagnosable, and already contribute to release confidence.",
    focus: "Scale safely, optimize structure, and accelerate with confidence.",
  },
];

const problemEntries = [
  {
    title: "Fix Flaky Tests at the System Level",
    href: "/offerings/fix-flaky-tests/",
    summary:
      "For teams dealing with unstable automation, noisy CI, and low trust in results.",
    image: "/images/problem-unstable-ci.png",
  },
  {
    title: "Turn Test Results Into Clear Release Decisions",
    href: "/offerings/release-decisions/",
    summary:
      "For teams that need better GO / WARN / BLOCK clarity before release.",
    image: "/images/problem-unclear-release.png",
  },
  {
    title: "Modernize Automation Without Destabilizing Delivery",
    href: "/offerings/modernize-without-disruption/",
    summary:
      "For teams that need progress without rewrite-first disruption.",
    image: "/images/problem-modernization-fear.png",
  },
  {
    title: "Diagnose Failures Without Reruns",
    href: "/offerings/diagnose-without-reruns/",
    summary:
      "For teams whose artifacts and debug flow are too weak to support first-run diagnosis.",
    image: "/images/problem-weak-artifacts.png",
  },
];

const paths = [
  {
    title: "No AI",
    href: "/offerings/no-ai/",
    kicker: "Deterministic QA System",
    summary:
      "Build a system you can trust step by step, with full transparency and no generated artifacts.",
    bullets: [
      "Capability mapping",
      "Locator strategy",
      "Scenario design",
      "Deterministic test construction",
      "Clear execution and observation",
    ],
  },
  {
    title: "Some AI",
    href: "/offerings/some-ai/",
    kicker: "Controlled AI QA System",
    summary:
      "Introduce AI carefully where it helps, while keeping strict validation and human-readable structure.",
    bullets: [
      "AI-assisted planning",
      "Validated locator suggestions",
      "Controlled generation",
      "Deterministic execution",
      "Failure analysis before trust",
    ],
  },
  {
    title: "AI Forward",
    href: "/offerings/ai-forward/",
    kicker: "AI-Accelerated QA System",
    summary:
      "Move faster with AI-generated assets, while preserving control through validation, artifacts, triage, and release gates.",
    bullets: [
      "Accelerated generation",
      "Validation layer",
      "Structured artifacts",
      "Automated triage",
      "GO / WARN / BLOCK release logic",
    ],
  },
];

import Hero from "../../components/Hero.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Offerings | QA Test Lab</title>
    <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="theme-color" content="#0b0e14" />
    <meta
      name="description"
      content="Start with the QA problem you need to solve first, then move into the right modernization path: deterministic, controlled AI, or AI-forward."
    />
    <style>
      :root {
        --bg: #0b0e14;
        --panel: #121827;
        --text: #e6e9ef;
        --muted: #aab2c5;
        --link: #7aa2ff;
        --border: #24304d;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
        background: var(--bg);
        color: var(--text);
      }

      a {
        color: var(--link);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }
      .video-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 16px;
      overflow: hidden;
      background: #000;
    }

    .video-frame iframe {
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
    }

    .video-logo {
      position: absolute;
      right: 20px;
      bottom: 20px;
      z-index: 2;
      pointer-events: none;

      padding: 8px 12px;
      border-radius: 12px;
      background: rgba(11, 14, 20, 0.55);
      border: 1px solid rgba(255,255,255,0.08);
      backdrop-filter: blur(6px);
    }

    .video-logo img {
      height: 24px;
    }

      .wrap {
        max-width: 1160px;
        margin: 0 auto;
        padding: 20px 18px 56px;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(10px);
        background: rgba(11, 14, 20, 0.78);
        border-bottom: 1px solid var(--border);
        padding: 12px 0;
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
      }

      .brand {
        font-weight: 750;
        letter-spacing: 0.2px;
      }

      .navlinks {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        font-size: 14px;
      }

      .pill {
        display: inline-block;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.04);
        padding: 7px 10px;
        border-radius: 999px;
        color: var(--text);
      }

      /* .problem-card__image {
        width: 100%;
        height: 140px;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
      }
      .problem-card__image img {
        transition: transform 0.4s ease;
      }

      .problem-card:hover .problem-card__image img {
        transform: scale(1.04);
      }

      .problem-card {
        padding: 0;              /* 🔥 critical */
        overflow: hidden;        /* keeps image clipped to rounded corners */
        border-radius: 18px;     /* match your system */
      } */

      .hero {
        padding: 28px 0 12px;
      }
      .problem-card__body {
        padding: 18px;
      }

      .h1 {
        font-size: 42px;
        line-height: 1.08;
        margin: 0 0 10px;
        letter-spacing: -0.6px;
      }

      .lead {
        color: var(--muted);
        font-size: 17px;
        line-height: 1.65;
        max-width: 920px;
        margin: 0;
      }

      .grid {
        display: grid;
        gap: 14px;
      }

      .grid2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .grid3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .grid4 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 18px;
        margin-top: 14px;
        box-shadow: 0 0 0 1px rgba(255,255,255,0.02);
      }

      h2 {
        margin: 0 0 10px;
        font-size: 24px;
      }

      h3 {
        margin: 0 0 10px;
        font-size: 18px;
      }

      .kicker {
        font-size: 13px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
      }

      p, li {
        color: var(--muted);
        line-height: 1.6;
      }

      ul {
        margin: 10px 0 0 18px;
      }

      li {
        margin: 6px 0;
      }

      .cta-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 14px;
      }

      .button {
        display: inline-block;
        border: 1px solid var(--border);
        background: var(--panel);
        padding: 11px 14px;
        border-radius: 12px;
        color: var(--text);
        font-weight: 600;
      }

      .button.primary {
        background: rgba(122, 162, 255, 0.12);
        border-color: #3a5ca8;
      }

      .section-title {
        margin-top: 28px;
      }

      .small {
        font-size: 14px;
        color: var(--muted);
      }

      .divider {
        height: 1px;
        background: var(--border);
        margin: 24px 0;
      }

      .trust-level {
        font-weight: 700;
        color: var(--text);
        margin-bottom: 8px;
      }

      footer {
        margin-top: 32px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 14px;
      }

      @media (max-width: 920px) {
        .grid2, .grid3, .grid4 {
          grid-template-columns: 1fr;
        }

        .h1 {
          font-size: 34px;
        }
      }
    </style>
  </head>

  <body>
    <div class="nav">
      <div class="wrap">
        <div class="nav-inner">
          <div class="brand">QA Test Lab</div>
          <div class="navlinks">
            <a class="pill" href="/">Lab</a>
            <a class="pill" href="/offerings/">Offerings</a>
            <a class="pill" href="/#runbooks">Runbooks</a>
            <a class="pill" href="/contact/">Contact</a>
          </div>
        </div>
      </div>
    </div>
    
    <div class="wrap">
    <Hero
      title="Modernize QA Without Losing Release Confidence"
      description="QA ALIGN is a deterministic automation system for teams dealing with flaky tests, weak CI trust, poor failure diagnosability, and unclear release decisions. Start with the problem you need to solve first, then move into the right modernization path."
      primaryHref="/contact/"
      primaryText="Request a Technical Review"
      secondaryHref="/#sprints"
      secondaryText="See Sprint Proof"
      imageSrc="/images/assessment-report.png"
      imageAlt="QA automation assessment report"
    />
    <section class="report-preview" aria-labelledby="video-demo-title">
      <p id="video-demo-title" class="report-preview__label">
        See QA ALIGN in Action
      </p>
    
      <div class="report-preview__frame">
        <div class="video-frame">
          <iframe
            src="https://www.youtube.com/embed/Rpl2zjYRGAY?rel=0&modestbranding=1"
            title="QA ALIGN Demo"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

      <section class="section-title">
        <h2>Start with the problem you need to solve first</h2>
        <div class="grid grid4">

          {problemEntries.map((item) => (
            <ProblemCard {...item} />
          ))}
          

        </div>
      </section>

      <div class="divider"></div>

      <section>
        <h2>What QA ALIGN changes</h2>
        <div class="card">
          <p>
            QA ALIGN is not generic QA automation. It is a modernization system designed to improve
            trust, diagnosability, and release decision clarity.
          </p>
          <ul>
            <li>API-first state setup</li>
            <li>Artifact-driven failure analysis</li>
            <li>Structured failure outputs</li>
            <li>CI-integrated diagnosability</li>
            <li>Release gate decisioning</li>
            <li>Phased modernization paths</li>
          </ul>
        </div>
      </section>

      <div class="divider"></div>

      <section id="paths" class="section-title">
        <h2>Choose the right modernization path</h2>
        <p class="small">
          Once the first problem is clear, the next step is choosing the right modernization style.
        </p>
        <div class="grid grid3">
          {paths.map((path) => (
            <div class="card">
              <div class="kicker">{path.kicker}</div>
              <h3>{path.title}</h3>
              <p>{path.summary}</p>
              <ul>
                {path.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
              <div class="cta-row">
                <a class="button primary" href={path.href}>Open path</a>
              </div>
            </div>
          ))}
        </div>
      </section>

      <div class="divider"></div>

      <section>
        <h2>Trust level determines where we start</h2>
        <p class="small">
          Before introducing speed, scale, or AI, the first question is simple:
          how much can your team trust the current system?
        </p>

        <div class="grid grid3">
          {trustMatrix.map((item) => (
            <div class="card">
              <div class="trust-level">{item.level}</div>
              <p>{item.description}</p>
              <p><strong style="color:var(--text);">How we respond:</strong> {item.focus}</p>
            </div>
          ))}
        </div>
      </section>

      <div class="divider"></div>

      <section>
        <h2>Every engagement starts with anti-pattern validation</h2>
        <p>
          Before recommending a sprint path, I assess the current system for the failure patterns
          that usually destroy trust first.
        </p>
        <div class="grid grid2">
          <div class="card">
            <h3>What I check first</h3>
            <ul>
              <li>Shared state and order-dependent tests</li>
              <li>Brittle locator strategy</li>
              <li>Environment drift between local and CI</li>
              <li>Rerun-based debugging habits</li>
              <li>Lack of artifact-first diagnosability</li>
              <li>No usable release decision logic</li>
            </ul>
          </div>
          <div class="card">
            <h3>What that produces</h3>
            <ul>
              <li>Current trust level: low, medium, or high</li>
              <li>Recommended system path</li>
              <li>Recommended sprint entry point</li>
              <li>Immediate next step for the first week</li>
            </ul>
          </div>
        </div>
      </section>

      <div class="divider"></div>

      <section>
        <h2>Where the sprint system fits</h2>
        <p>
          The offerings do not replace the lab. They route teams into the right parts of it.
          Sprint callouts are used where they matter most.
        </p>
        <div class="grid grid2">
          <div class="card">
            <h3>Typical low-trust entry</h3>
            <ul>
              <li>Sprint 3: CI Diagnosability</li>
              <li>Sprint 4: Flake Taxonomy and Guardrails</li>
              <li>Sprint 5: Test Data and State Reset</li>
            </ul>
          </div>
          <div class="card">
            <h3>Typical acceleration path</h3>
            <ul>
              <li>Sprint 6: Time-to-Signal and Release Gates</li>
              <li>Sprint 14: Agent Artifact Contract and Failure Taxonomy</li>
              <li>Sprint 15–17: Triage and release decision automation</li>
            </ul>
          </div>
        </div>
      </section>

      <div class="divider"></div>

      <section>
        <h2>Start with a Technical Signal Review</h2>
        <div class="card">
          <p>
            A good first step is not a rewrite. It is a focused review of your current automation signal.
          </p>
          <ul>
            <li>Current trust level</li>
            <li>Key anti-patterns</li>
            <li>Likely sprint entry point</li>
            <li>Recommended modernization path</li>
            <li>First correction priority</li>
          </ul>
          <div class="cta-row">
            <a class="button primary" href="/contact/">Request a Technical Review</a>
            <a class="button" href="/#runbooks">Review QA ALIGN Proof</a>
          </div>
        </div>
      </section>

      <footer>
        QA Test Lab — the offerings hub connecting pain-entry pages, modernization paths, and sprint-based proof.
      </footer>
    </div>
  </body>
</html>
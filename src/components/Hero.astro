---
const {
  title,
  description,
  primaryHref = "/contact/",
  primaryText = "Request a Technical Review",
  secondaryHref = "/#sprints",
  secondaryText = "See Sprint Proof",
  imageSrc = "/images/modern-assessment-report.png",
  imageAlt = "QA automation assessment report"
} = Astro.props;
---

<section class="hero">
  <div class="hero-grid">
    <div class="hero-text">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-lead">{description}</p>

      <div class="hero-actions">
        <a href={primaryHref} class="hero-button hero-button--primary">{primaryText}</a>
        <a href={secondaryHref} class="hero-button hero-button--secondary">{secondaryText}</a>
      </div>
    </div>

    <div class="hero-image">
      <img src={imageSrc} alt={imageAlt} />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 72px 0 36px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(420px, 0.9fr);
    gap: 56px;
    align-items: center;
  }

  .hero-text {
    max-width: 640px;
  }

  .hero-title {
    margin: 0 0 18px;
    font-size: 56px;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: #e6e9ef;
  }

  .hero-lead {
    margin: 0;
    font-size: 17px;
    line-height: 1.65;
    color: #aab2c5;
    max-width: 58ch;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 24px;
  }

  .hero-actions a.hero-button,
  .hero-actions a.hero-button:visited,
  .hero-actions a.hero-button:hover,
  .hero-actions a.hero-button:active {
    display: inline-block;
    padding: 12px 16px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 16px;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .hero-actions a.hero-button--primary,
  .hero-actions a.hero-button--primary:visited {
    background: rgba(122, 162, 255, 0.15);
    border: 1px solid #3a5ca8;
    color: #e6e9ef;
  }

  .hero-actions a.hero-button--primary:hover,
  .hero-actions a.hero-button--primary:active {
    background: rgba(122, 162, 255, 0.24);
    border-color: #4a6fe3;
    color: #ffffff;
  }

  .hero-actions a.hero-button--secondary,
  .hero-actions a.hero-button--secondary:visited {
    background: #121827;
    border: 1px solid #24304d;
    color: #e6e9ef;
  }

  .hero-actions a.hero-button--secondary:hover,
  .hero-actions a.hero-button--secondary:active {
    background: rgba(255, 255, 255, 0.04);
    border-color: #30415f;
    color: #ffffff;
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image img {
    display: block;
    width: 100%;
    max-width: 560px;
    border-radius: 18px;
    box-shadow:
      0 28px 80px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(255,255,255,0.04);
  }

  @media (max-width: 920px) {
    .hero {
      padding: 44px 0 20px;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .hero-title {
      font-size: 40px;
    }

    .hero-image img {
      max-width: 100%;
    }
  }
</style>

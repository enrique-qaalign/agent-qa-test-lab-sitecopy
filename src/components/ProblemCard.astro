---
const { title, summary, href, image } = Astro.props;
---

<a href={href} class="card problem-card">
  <div class="problem-card__image">
    <img src={image} alt="" />
  </div>

  <div class="problem-card__body">
    <h3>{title}</h3>
    <p>{summary}</p>
    <span class="problem-card__cta">Explore this page →</span>
  </div>
</a>

<style>
    .problem-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    border-radius: 18px;
    
    text-decoration: none;   /* 🔥 remove underline */
    color: inherit;          /* 🔥 remove purple */
    }

    .problem-card * {
    text-decoration: none;
    color: inherit;
    }

  .problem-card:hover {
    text-decoration: none;
    border-color: #3a5ca8;
  }

  .problem-card__image {
    width: 100%;
    aspect-ratio: 2.5 / 1;
    background: #05070d;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .problem-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(1.05) contrast(1.08) saturate(1.08);
    transition: transform 0.25s ease;
  }

  .problem-card:hover .problem-card__image img {
    transform: scale(1.03);
  }

  .problem-card__body {
    padding: 18px;
  }

  .problem-card__body h3 {
    margin: 0 0 10px;
    color: var(--text);
  }

  .problem-card__body p {
    margin: 0;
    color: var(--muted);
  }

  .problem-card__cta {
    display: inline-block;
    margin-top: 16px;
    color: var(--link);
    font-weight: 700;
  }
</style>
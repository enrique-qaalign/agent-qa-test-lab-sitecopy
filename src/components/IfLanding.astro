---
const { title, subtitle, problemPoints = [], proof } = Astro.props;
---

<section class="container">

  <h1>{title}</h1>
  <p class="subtitle">{subtitle}</p>

  <div class="cta-row">
    <a href="/intake" class="btn-primary">Get Your Free Automation Assessment</a>
    <a href="/contact" class="btn-secondary">Schedule Review Meeting</a>
  </div>

  <h2>The Problem</h2>
  <ul>
    {problemPoints.map((p: string) => <li>{p}</li>)}
  </ul>

  <div class="grid">
    <div class="card">
      <h3 class="bad">Raw CI Output</h3>
      <pre>
ERROR: timeout
Retrying...
Retrying...
Stack trace...
      </pre>
    </div>

    <div class="card highlight">
      <h3 class="good">QA ALIGN Artifact</h3>
      <pre>{JSON.stringify(proof, null, 2)}</pre>
    </div>
  </div>

  <h2>How It Works</h2>
  <ol>
    <li>Submit your repo or URL</li>
    <li>QA ALIGN runs a deterministic assessment</li>
    <li>Review findings in 15 minutes</li>
    <li>Decide what to fix first</li>
  </ol>

  <div class="form-card">
  <h3>Start with a Free Assessment</h3>

  <input placeholder="Your Email" />
  <input placeholder="Repo or Site URL" />

  <label class="checkbox">
    <input type="checkbox" />
    NDA confidentiality acknowledgment
  </label>

  <button class="btn-primary">Get Assessment</button>
</div>
 

</section>

<style>
.container {
  background: #0b0e14;
  color: white;
  padding: 80px 20px;
  font-family: system-ui;
  max-width: 1100px;
  margin: 0 auto;
}

.container h1 {
  font-size: 36px;
  margin-bottom: 16px;
}

.subtitle {
  color: #9ca3af;
  margin-bottom: 24px;
}
.form-card {
  background: #111827;
  padding: 24px;
  border-radius: 12px;
  max-width: 480px;
  margin-top: 40px;
}

.checkbox {
  display: flex;
  gap: 8px;
  align-items: center;
  margin: 10px 0;
}

.cta-row {
  display: flex;
  gap: 12px;
  margin-bottom: 40px;
}

.btn-primary {
  background: #2563eb;
  padding: 12px 18px;
  border-radius: 8px;
  color: white;
  text-decoration: none;
}

.btn-secondary {
  border: 1px solid #555;
  padding: 12px 18px;
  border-radius: 8px;
  color: white;
  text-decoration: none;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin: 40px 0;
}
<div style="margin-top: 20px;">
  <a href="/intake" class="btn-primary">
    Get Your Free Automation Assessment
  </a>
</div>

.card {
  background: #111827;
  padding: 16px;
  border-radius: 10px;
}

.highlight {
  border: 1px solid #2563eb;
}

.bad {
  color: #f87171;
}

.good {
  color: #2563eb;
}

pre {
  font-size: 12px;
  color: #d1d5db;
}

.form {
  margin-top: 40px;
}

.form input {
  display: block;
  width: 100%;
  margin-bottom: 10px;
  padding: 10px;
  background: #000;
  border: 1px solid #444;
  color: white;
}

.form button {
  background: #2563eb;
  padding: 12px;
  border: none;
  color: white;
  border-radius: 8px;
}
</style>